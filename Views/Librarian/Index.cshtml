@{
    ViewData["Title"] = "Панель библиотекаря";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="d-flex align-items-center gap-3 mb-4">
    <div>
        <h3 class="fw-bold mb-0" style="color: var(--blue-dk);">Найти читателя</h3>
        <span class="text-muted small">Введите ID читателя для просмотра информации и выдачи книг</span>
    </div>
</div>

<div class="d-flex gap-3 flex-wrap">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#findReaderModal">
        🔍 Найти читателя
    </button>
</div>

<!-- Модалка: Найти читателя -->
<div class="modal fade" id="findReaderModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Найти читателя</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="FindReader" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <label class="form-label">ID читателя</label>
                    <input type="number" name="readerId" class="form-control" required min="1" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Найти</button>
                </div>
            </form>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Главная";
    var isAdmin     = User.IsInRole("Admin");
    var isLibrarian = User.IsInRole("Librarian");
    var isReader    = User.IsInRole("Reader");
    var isStaff     = isAdmin || isLibrarian;
}

@if (isStaff)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: var(--blue-dk);">Панель управления</h3>
            <span class="text-muted small">
                Добро пожаловать, @User.Identity!.Name
                &nbsp;·&nbsp;
                <span class="badge" style="background: var(--blue-lt);">
                    @(isAdmin ? "Администратор" : "Библиотекарь")
                </span>
            </span>
        </div>
    </div>

    <div class="row g-3">

        <div class="col-12">
            <div class="text-muted small fw-semibold text-uppercase mb-2"
                 style="letter-spacing:.05em;">📚 Книжный фонд</div>
        </div>

        @{
            var fundCards = new (string Controller, string Action, string Icon, string Title, string Desc)[]
            {
                ("Authors",      "Index", "✍️",  "Авторы",      "Управление авторами книг"),
                ("Books",        "Index", "📖",  "Книги",       "Каталог произведений"),
                ("VersionBooks", "Index", "🖨️",  "Издания",     "Версии и тиражи книг"),
                //("ExampleBooks", "Index", "📦",  "Экземпляры",  "Физические экземпляры"),
                ("Categories",   "Index", "🏷️",  "Жанры",       "Классификация"),
                ("Publishers",   "Index", "🏢",  "Издатели",    "Издательские дома"),
            };
        }

        @foreach (var card in fundCards)
        {
            <div class="col-md-4 col-lg-3">
                <a asp-controller="@card.Controller" asp-action="@card.Action"
                   class="text-decoration-none">
                    <div class="card h-100 shadow-sm p-3 card-hover">
                        <div class="fs-2 mb-2">@card.Icon</div>
                        <div class="fw-semibold" style="color: var(--blue-dk);">@card.Title</div>
                        <div class="text-muted small">@card.Desc</div>
                    </div>
                </a>
            </div>
        }

        @if (isLibrarian)
        {
            <div class="col-12 mt-2">
                <div class="text-muted small fw-semibold text-uppercase mb-2"
                     style="letter-spacing:.05em;">🔄 Обслуживание читателей</div>
            </div>
            
            var serviceCards = new (string Controller, string Action, string Icon, string Title, string Desc)[]
            {
                ("Loans", "Index", "📋", "Выдачи", "Активные и закрытые выдачи"),
                ("Fines", "Index", "💰", "Штрафы", "Штрафы и задолженности"),
                ("Librarian",  "Index", "🔍", "Найти читателя",    "Поиск по ID, выдача, штрафы"),
            };
            
        

            @foreach (var card in serviceCards)
            {
                <div class="col-md-4 col-lg-3">
                    <a asp-controller="@card.Controller" asp-action="@card.Action"
                       class="text-decoration-none">
                        <div class="card h-100 shadow-sm p-3 card-hover">
                            <div class="fs-2 mb-2">@card.Icon</div>
                            <div class="fw-semibold" style="color: var(--blue-dk);">@card.Title</div>
                            <div class="text-muted small">@card.Desc</div>
                        </div>
                    </a>
                </div>
            }
        }
        

        @if (isAdmin)
        {
            <div class="col-12 mt-2">
                <div class="text-muted small fw-semibold text-uppercase mb-2"
                     style="letter-spacing:.05em;">⚙️ Администрирование</div>
            </div>

            
            var adminCards = new[] {
                (Controller: "Users",  Action: "Index", Icon: "👥", Title: "Пользователи", Desc: "..."),
                (Controller: "Roles",  Action: "Index", Icon: "🔐", Title: "Роли",         Desc: "..."),
                // 👇 Новая карточка
                (Controller: "Admin",  Action: "BookStats", Icon: "📊", Title: "Статистика книг", Desc: "Выдано, доступно, всего экземпляров"),
            };
            

            @foreach (var card in adminCards)
            {
                <div class="col-md-4 col-lg-3">
                    <a asp-controller="@card.Controller" asp-action="@card.Action"
                       class="text-decoration-none">
                        <div class="card h-100 shadow-sm p-3 card-hover"
                             style="border-left: 4px solid var(--purple);">
                            <div class="fs-2 mb-2">@card.Icon</div>
                            <div class="fw-semibold" style="color: var(--blue-dk);">@card.Title</div>
                            <div class="text-muted small">@card.Desc</div>
                        </div>
                    </a>
                </div>
            }
        }

    </div>
}
else if (isReader)
{
    <div class="text-center py-5">
        <div style="font-size: 64px;">📚</div>
        <h3 class="fw-bold mt-3" style="color: var(--blue-dk);">
            Добро пожаловать в БиблиоСистему
        </h3>
        <p class="text-muted mb-4">
            Привет, <strong>@User.Identity!.Name</strong>!
            Ищи книги, бронируй и следи за своими выдачами.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="ExampleBooks" asp-action="Catalog"
               class="btn btn-primary px-4">📖 Перейти в каталог</a>
            <a asp-controller="Profile" asp-action="Index"
               class="btn btn-outline-secondary px-4">👤 Мой профиль</a>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <div style="font-size: 64px;">🏛️</div>
        <h3 class="fw-bold mt-3" style="color: var(--blue-dk);">Городская библиотека</h3>
        <p class="text-muted mb-4" style="max-width: 480px; margin: 0 auto 24px;">
            Найдите нужную книгу, узнайте о её наличии и забронируйте онлайн.
            Для бронирования необходимо войти в систему.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="ExampleBooks" asp-action="Catalog"
               class="btn btn-primary px-4">📖 Открыть каталог</a>
            <a asp-controller="Account" asp-action="Login"
               class="btn btn-outline-secondary px-4">Войти</a>
        </div>
    </div>
}

<style>
    .card-hover {
        transition: transform .15s, box-shadow .15s;
        cursor: pointer;
    }
    .card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(31,59,96,.15) !important;
    }
</style>

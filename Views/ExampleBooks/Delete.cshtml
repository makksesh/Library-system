@model LibApp.Models.ExampleBook
@using LibApp.Models

@{
    ViewData["Title"] = "Удаление экземпляра";
    var canDelete = ViewBag.ErrorMessage == null;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0 text-danger">🗑️ Удаление экземпляра</h3>
        <span class="text-muted small font-monospace">ID: @Model.ExampleBookId</span>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← К списку</a>
</div>

@if (!canDelete)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="max-width:560px;">
        <span style="font-size:1.3em;">⛔</span>
        <span>@ViewBag.ErrorMessage</span>
    </div>
}

<div class="card border-danger shadow-sm mb-3" style="max-width: 560px;">
    <div class="card-header bg-danger bg-opacity-10 text-danger fw-semibold">
        Вы действительно хотите удалить этот экземпляр?
    </div>
    <div class="card-body">

        <div class="mb-3 pb-3 border-bottom">
            <div class="text-muted small fw-semibold text-uppercase mb-1"
                 style="letter-spacing:.05em;">Издание</div>
            <div class="fw-semibold fs-5">@Model.VersionBook?.Name</div>
            <div class="text-muted small">
                @Model.VersionBook?.Book?.Author?.FullName
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6">
                <span class="text-muted small d-block">Полка</span>
                <span class="font-monospace">@(Model.ShelfCode ?? "—")</span>
            </div>
            <div class="col-6">
                <span class="text-muted small d-block">Статус</span>
                <strong>@Model.Status</strong>
            </div>
            <div class="col-6">
                <span class="text-muted small d-block">Состояние</span>
                <strong>@Model.Condition</strong>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="ExampleBookId" />
            <div class="d-flex gap-2">
                @if (canDelete)
                {
                    <button type="submit" class="btn btn-danger w-100">
                        🗑️ Пометить как удалённый
                    </button>
                }
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Отмена</a>
            </div>
        </form>

    </div>
</div>
